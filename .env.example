# Primy — environment variables reference.
#
# Copy this file to `.env.local` and fill in real values. `.env.local`
# is gitignored; this file (`.env.example`) is committed and serves as
# the source of truth for which variables exist and what they do.

# ── Database (Neon Postgres) ──
DATABASE_URL=postgresql://...

# (optional) Separate Neon test branch for integration tests.
# DATABASE_URL_TEST=postgresql://...

# ── NextAuth ──
NEXTAUTH_SECRET=  # generate via `openssl rand -base64 32`
NEXTAUTH_URL=http://localhost:3000

# ── AI providers ──
# Provider routing happens in src/lib/ai/modelRouter.ts. AI_PROVIDER
# selects which set of models to use; the matching API key must be set.
AI_PROVIDER=openai     # "openai" | "google"
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=

# ── Vercel Blob (file uploads) ──
BLOB_READ_WRITE_TOKEN=

# ── Vercel Cron secret ──
# Set this in Vercel project settings (production). Vercel cron auto-
# injects `Authorization: Bearer ${CRON_SECRET}` on scheduled invocations.
# If unset, every request to /api/cron/* is rejected as unauthorized.
CRON_SECRET=  # generate via `openssl rand -hex 32`

# ── Plan limits enforcement ──
# Keep false until a payment gateway is wired. When false, withPlanLimit
# is a passthrough and every user effectively gets Pro behavior.
ENFORCE_PLAN_LIMITS=false

# ── Email (Resend) ──
RESEND_API_KEY=re_...

# ── (optional) Unsplash for deck images ──
UNSPLASH_ACCESS_KEY=
